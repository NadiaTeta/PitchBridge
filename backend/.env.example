# Server
NODE_ENV=development
PORT=5000
API_VERSION=v1

# Database
MONGODB_URI=mongodb://localhost:27017/pitchbridge

# Auth
JWT_SECRET=your-secret-key
JWT_EXPIRE=30d

# Client (for CORS)
CLIENT_URL=http://localhost:5173

# Email – real SMTP only. Verification codes go to users' real inboxes.
# If you had Mailtrap here, REPLACE with real SMTP (app will error if Mailtrap is used).
# Gmail: smtp.gmail.com, port 587, App Password from https://myaccount.google.com/apppasswords
# SendGrid/Outlook: use your provider's SMTP host and credentials.
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password
EMAIL_FROM=PitchBridge <noreply@yourdomain.com>

# Optional: rate limit & uploads
# RATE_LIMIT_WINDOW_MS=900000
# RATE_LIMIT_MAX_REQUESTS=1000
# MAX_FILE_SIZE=52428800
# ALLOWED_FILE_TYPES=image/jpeg,image/png,...
